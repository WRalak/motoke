# Motoke Environment Configuration
# Copy this file to .env and fill in your actual credentials

# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/motoke"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-jwt-key-here"

# Email Service Configuration (SendGrid)
SENDGRID_API_KEY="SG.your-sendgrid-api-key-here"
EMAIL_FROM="noreply@motoke.co.ke"
EMAIL_FROM_NAME="Motoke"

# SMS Service Configuration (Twilio)
TWILIO_ACCOUNT_SID="ACyour-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+254123456789"
TWILIO_MESSAGING_SERVICE_SID="MGyour-messaging-service-sid"

# Push Notification Service (Firebase)
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_PRIVATE_KEY_ID="your-firebase-private-key-id"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-firebase-private-key\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xyz@your-project.iam.gserviceaccount.com"

# File Upload Configuration
CLOUDINARY_CLOUD_NAME="your-cloudinary-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# Payment Gateway Configuration
MPESA_CONSUMER_KEY="your-mpesa-consumer-key"
MPESA_CONSUMER_SECRET="your-mpesa-consumer-secret"
MPESA_PASSKEY="your-mpesa-passkey"
MPESA_SHORTCODE="174379"

# Redis Configuration (for caching/sessions)
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD="your-redis-password"

# Application Configuration
NODE_ENV="development"
APP_URL="http://localhost:3000"
API_BASE_URL="http://localhost:3000/api"

# Security Configuration
CORS_ORIGIN="http://localhost:3000"
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Monitoring and Analytics
SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"
GOOGLE_ANALYTICS_ID="GA-XXXXXXXXX"

# JWT Configuration
JWT_SECRET="your-jwt-secret-key-here"
JWT_EXPIRES_IN="7d"

# Email Templates Configuration
EMAIL_TEMPLATE_DIR="./templates"
EMAIL_LOGO_URL="https://motoke.co.ke/logo.png"

# SMS Configuration
SMS_COUNTRY_CODE="254"
SMS_MAX_LENGTH=160

# Notification Settings
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY_MS=5000

# Development Only
SKIP_EMAIL_VERIFICATION=true
SKIP_SMS_VERIFICATION=true
