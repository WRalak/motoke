// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  password          String
  name              String
  phone             String?
  role              UserRole @default(CUSTOMER)
  status            UserStatus @default(ACTIVE)
  emailVerified     Boolean  @default(false)
  phoneVerified     Boolean  @default(false)
  twoFactorEnabled  Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  lastLoginAt       DateTime?

  // Relations
  customerProfile   CustomerProfile?
  dealerProfile     DealerProfile?
  salespersonProfile SalespersonProfile?
  bids              Bid[]
  proxyBids         ProxyBid[]
  leads             Lead[]
  sales             Sale[]
  notifications     Notification[]
  sessions          AuthSession[]

  @@map("users")
}

model CustomerProfile {
  id                String @id @default(cuid())
  userId            String @unique
  county            String
  city              String
  dateOfBirth       DateTime
  creditScore       Int?
  income            Float?
  employmentStatus  String?
  employer          String?
  preferences       Json? // { vehicleTypes, priceRange, financing, insurance }
  documents         Json? // { licenseVerified, insuranceVerified, financingApproved }
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  user              User @relation(fields: [userId], references: [id], onDelete: Cascade)
  sales             Sale[]
  leads             Lead[]

  @@map("customer_profiles")
}

model DealerProfile {
  id                String @id @default(cuid())
  userId            String @unique
  businessName      String
  kraPin            String
  county            String
  city              String
  address           String
  phone             String
  email             String
  website           String?
  description       String?
  specialties       Json // e.g., ["Luxury", "SUV", "Electric"]
  established       Int
  rating            Float @default(0)
  reviewCount       Int @default(0)
  verified          Boolean @default(false)
  subscriptionPlan  SubscriptionPlan @default(FREE)
  subscriptionEndsAt DateTime?
  mpesaNumber       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  user              User @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicles          Vehicle[]
  sales             Sale[]

  @@map("dealer_profiles")
}

model SalespersonProfile {
  id                String @id @default(cuid())
  userId            String @unique
  hireDate          DateTime
  commissionRate    Float @default(3.0)
  monthlyTarget     Float @default(150000)
  ytdSales          Float @default(0)
  ytdCommission     Float @default(0)
  specialties       Json
  status            String @default("active")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  user              User @relation(fields: [userId], references: [id], onDelete: Cascade)
  sales             Sale[]
  leads             Lead[]

  @@map("salesperson_profiles")
}

model Vehicle {
  id                String @id @default(cuid())
  make              String
  model             String
  year              Int
  mileage           Int
  vin               String @unique
  price             Float
  status            VehicleStatus @default(PENDING)
  images            Json
  description       String
  features          Json
  engineSize        String?
  transmission      String?
  fuelType          String?
  driveType         String?
  colour            String?
  county            String
  ntsaStatus        NtsaStatus
  dealerId          String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  dealer            DealerProfile @relation(fields: [dealerId], references: [userId])
  bids              Bid[]
  proxyBids         ProxyBid[]
  auctionVehicles   AuctionVehicle[]
  sales             Sale[]

  @@map("vehicles")
}

model Auction {
  id                String @id @default(cuid())
  title             String
  description       String
  type              AuctionType @default(ONLINE)
  status            AuctionStatus @default(UPCOMING)
  startDate         DateTime
  endDate           DateTime
  location          String?
  onlineUrl         String?
  organizer         String
  fees              Json // { buyerPremium, registrationFee, otherFees }
  requirements      Json // { deposit, maxBidders, preApproval }
  images            Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  auctionVehicles   AuctionVehicle[]

  @@map("auctions")
}

model AuctionVehicle {
  id                String @id @default(cuid())
  vehicleId         String
  auctionId         String
  startingBid       Float
  currentBid        Float?
  reservePrice      Float?
  bidCount          Int @default(0)
  status            String @default("pending")
  highlights        Json
  conditionReport   Json // { overall, exterior, interior, mechanical, tires, documentation }
  images            Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  vehicle           Vehicle @relation(fields: [vehicleId], references: [id])
  auction           Auction @relation(fields: [auctionId], references: [id])
  bids              Bid[]
  proxyBids         ProxyBid[]

  @@map("auction_vehicles")
}

model Bid {
  id                String @id @default(cuid())
  vehicleId         String
  auctionVehicleId   String
  bidderId          String
  amount            Float
  timestamp         DateTime @default(now())
  type              BidType @default(MANUAL)
  status            BidStatus @default(ACTIVE)
  paymentId         String? // M-Pesa transaction ID

  // Relations
  bidder            User @relation(fields: [bidderId], references: [id])
  vehicle           Vehicle @relation(fields: [vehicleId], references: [id])
  auctionVehicle    AuctionVehicle @relation(fields: [auctionVehicleId], references: [id])

  @@map("bids")
}

model ProxyBid {
  id                String @id @default(cuid())
  vehicleId         String
  auctionVehicleId   String
  bidderId          String
  maximumAmount     Float
  currentBid        Float @default(0)
  incrementAmount   Float
  isActive          Boolean @default(true)
  createdAt         DateTime @default(now())
  lastTriggeredAt   DateTime?
  autoRenew         Boolean @default(false)

  // Relations
  bidder            User @relation(fields: [bidderId], references: [id])
  vehicle           Vehicle @relation(fields: [vehicleId], references: [id])
  auctionVehicle    AuctionVehicle @relation(fields: [auctionVehicleId], references: [id])

  @@map("proxy_bids")
}

model Sale {
  id                String @id @default(cuid())
  vehicleId         String
  dealerId          String
  customerId        String
  salespersonId     String?
  saleDate          DateTime @default(now())
  salePrice         Float
  saleType          SaleType @default(RETAIL)
  status            SaleStatus @default(PENDING)
  paymentMethod     PaymentMethod @default(CASH)
  commission        Float
  profit            Float
  taxes             Float
  fees              Json // { documentation, registration, other }
  notes             String?
  documents         Json? // { logbook, transfer, insurance }
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  vehicle           Vehicle @relation(fields: [vehicleId], references: [id])
  dealer            DealerProfile @relation(fields: [dealerId], references: [userId])
  customer          CustomerProfile @relation(fields: [customerId], references: [userId])
  salesperson       SalespersonProfile? @relation(fields: [salespersonId], references: [userId])
  buyer             User @relation(fields: [customerId], references: [id])

  @@map("sales")
}

model Lead {
  id                String @id @default(cuid())
  name              String
  email             String
  phone             String
  source            String
  status            LeadStatus @default(NEW)
  priority          String @default("medium")
  vehicleInterest   Json
  budget            Float?
  timeline          String?
  assignedTo        String? // Salesperson ID
  customerId        String?
  createdDate       DateTime @default(now())
  lastContactDate   DateTime?
  followUpDate      DateTime?
  notes             Json

  // Relations
  assignedSalesperson SalespersonProfile? @relation(fields: [assignedTo], references: [userId])
  customer          CustomerProfile? @relation(fields: [customerId], references: [userId])
  buyer             User? @relation(fields: [customerId], references: [id])

  @@map("leads")
}

model Notification {
  id                String @id @default(cuid())
  userId            String
  type              String
  title             String
  message           String
  data              Json? // Additional notification data
  read              Boolean @default(false)
  createdAt         DateTime @default(now())

  // Relations
  user              User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model AuthSession {
  id                String @id @default(cuid())
  userId            String
  token             String
  refreshToken      String
  expiresAt         DateTime
  isActive          Boolean @default(true)
  createdAt         DateTime @default(now())

  // Relations
  user              User @relation(fields: [userId], references: [id])

  @@map("auth_sessions")
}

model PlatformSettings {
  id                String @id @default(cuid())
  key               String @unique
  value             Json
  description       String?
  updatedAt         DateTime @updatedAt

  @@map("platform_settings")
}

model Transaction {
  id                String @id @default(cuid())
  type              TransactionType
  amount            Float
  currency          String @default("KES")
  status            TransactionStatus @default(PENDING)
  paymentMethod     String
  reference         String? // M-Pesa transaction ID
  metadata          Json? // Additional transaction data
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("transactions")
}

// Enums
enum UserRole {
  ADMIN
  DEALER
  CUSTOMER
  SALESPERSON
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum VehicleStatus {
  PENDING
  AVAILABLE
  SOLD
  REJECTED
}

enum NtsaStatus {
  CLEARED
  PENDING
  FAILED
}

enum AuctionType {
  LIVE
  ONLINE
  SEALED_BID
}

enum AuctionStatus {
  UPCOMING
  ACTIVE
  ENDED
  CANCELLED
}

enum BidType {
  MANUAL
  AUTO
  PROXY
}

enum BidStatus {
  ACTIVE
  OUTBID
  WINNING
}

enum SaleType {
  RETAIL
  AUCTION
  WHOLESALE
  FLEET
}

enum SaleStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  FINANCING
  LEASE
  TRADE
  MPESA
  BANK_TRANSFER
}

enum SubscriptionPlan {
  FREE
  STANDARD
  PRO
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  CLOSED_LOST
}

enum TransactionType {
  AUCTION_DEPOSIT
  LISTING_FEE
  SUBSCRIPTION
  COMMISSION
  SALE_PAYMENT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}
