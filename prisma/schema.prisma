// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User Management
model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  phone       String?
  role        Role     @default(USER)
  verified     Boolean  @default(false)
  avatar      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  vehicles    Vehicle[]
  listings    Listing[]
  bids        Bid[]
  messages     Message[]
  notifications Notification[]
  reviews     Review[]
  
  @@map("users")
}

model Role {
  USER        Role
  ADMIN       Role
  DEALER     Role
}

// Vehicle Management
model Vehicle {
  id          String   @id @default(cuid())
  make        String
  model       String
  year        Int
  mileage     Int
  vin         String   @unique
  price       Int
  status      VehicleStatus @default(AVAILABLE)
  description String?
  engineSize  String?
  transmission String?
  fuelType    String?
  driveType   String?
  colour      String?
  county      String?
  ntsaStatus  String?
  images      String[] // JSON array of image URLs
  features    String[] // JSON array of features
  
  // Foreign Keys
  dealerId    String
  dealer      Dealer?  @relation(fields: [dealerId], references: [id])
  listingId   String?
  listing     Listing? @relation(fields: [listingId], references: [id])
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("vehicles")
}

model VehicleStatus {
  AVAILABLE
  SOLD
  RESERVED
  PENDING
}

// Dealer Management
model Dealer {
  id           String    @id @default(cuid())
  name         String
  email        String   @unique
  phone        String
  address      String
  city         String
  state        String
  zipCode      String
  description  String?
  specialties  String[]   // JSON array of specialties
  rating       Float     @default(0)
  reviewCount  Int       @default(0)
  verified     Boolean    @default(false)
  established  String?
  logo         String?
  
  // Relations
  users        User[]
  vehicles     Vehicle[]
  
  // Timestamps
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@map("dealers")
}

// Listings (Vehicle for sale by users)
model Listing {
  id          String    @id @default(cuid())
  title       String
  description String
  price       Int
  status      ListingStatus @default(ACTIVE)
  
  // Foreign Keys
  vehicleId   String
  vehicle     Vehicle @relation(fields: [vehicleId], references: [id])
  
  sellerId    String
  seller      User @relation(fields: [sellerId], references: [id])
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("listings")
}

model ListingStatus {
  ACTIVE
  EXPIRED
  SOLD
  PENDING
}

// Auction Management
model Auction {
  id              String    @id @default(cuid())
  title           String
  description     String
  startBid       Int
  currentBid     Int?
  startDate       DateTime
  endDate         DateTime
  status          AuctionStatus @default(UPCOMING)
  
  // Foreign Keys
  vehicleId       String
  vehicle         Vehicle @relation(fields: [vehicleId], references: [id])
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@map("auctions")
}

model AuctionStatus {
  UPCOMING
  ACTIVE
  ENDED
  CANCELLED
}

// Bid Management
model Bid {
  id          String    @id @default(cuid())
  amount      Int
  status      BidStatus @default(PENDING)
  
  // Foreign Keys
  vehicleId   String
  vehicle     Vehicle @relation(fields: [vehicleId], references: [id])
  
  bidderId    String
  bidder      User @relation(fields: [bidderId], references: [id])
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("bids")
}

model BidStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

// Message Management
model Message {
  id          String    @id @default(cuid())
  content     String
  isRead      Boolean    @default(false)
  
  // Foreign Keys
  senderId    String
  sender      User @relation(fields: [senderId], references: [id])
  
  receiverId  String?
  receiver    User? @relation(fields: [receiverId], references: [id])
  
  // Optional foreign keys for context
  vehicleId   String?
  vehicle     Vehicle? @relation(fields: [vehicleId], references: [id])
  
  dealerId    String?
  dealer      Dealer? @relation(fields: [dealerId], references: [id])
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("messages")
}

// Notification Management
model Notification {
  id          String     @id @default(cuid())
  type        NotificationType
  title       String
  message     String
  isRead      Boolean     @default(false)
  
  // Optional action data
  actionUrl   String?
  actionText  String?
  
  // Foreign Keys
  userId      String
  user        User @relation(fields: [userId], references: [id])
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("notifications")
}

model NotificationType {
  BID
  OFFER
  MESSAGE
  AUCTION
  PAYMENT
  SYSTEM
}

// Review Management
model Review {
  id          String    @id @default(cuid())
  rating      Int
  comment     String
  
  // Foreign Keys
  userId      String
  user        User @relation(fields: [userId], references: [id])
  
  dealerId    String?
  dealer      Dealer? @relation(fields: [dealerId], references: [id])
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("reviews")
}

// Payment Management
model Payment {
  id            String     @id @default(cuid())
  amount         Int
  currency       String     @default("KES")
  status         PaymentStatus @default(PENDING)
  method         String?
  transactionId  String?    @unique
  
  // Foreign Keys
  userId         String
  user           User @relation(fields: [userId], references: [id])
  
  // Optional context
  vehicleId      String?
  vehicle        Vehicle? @relation(fields: [vehicleId], references: [id])
  
  listingId      String?
  listing        Listing? @relation(fields: [listingId], references: [id])
  
  // Timestamps
  dueDate        DateTime
  completedAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@map("payments")
}

model PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// M-Pesa Integration
model MpesaTransaction {
  id                String     @id @default(cuid())
  merchantRequestId  String     @unique
  checkoutRequestId String?    @unique
  amount            Int
  phoneNumber       String
  transactionId    String?
  status            String
  
  // Foreign Keys
  userId            String
  user              User @relation(fields: [userId], references: [id])
  
  paymentId         String?
  payment           Payment? @relation(fields: [paymentId], references: [id])
  
  // Timestamps
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@map("mpesa_transactions")
}
